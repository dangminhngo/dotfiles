# Darkoma for imv
# ~/.config/imv/config

# styling
[options]
background = #233435
fullscreen = false
overlay = true
overlay_text_color = #f4f8f8
overlay_background_color = #2d4244
overlay_background_alpha = ff
overlay_font = Jetka:11
overlay_position_bottom = false

# bindings
[binds]
j = next
k = prev
    